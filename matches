a = int(input("Enter no.of teams:"))
teams = []
for i in range(a):
    x = input("Enter team:")
    teams.append(x)
mathes = []
for i in range(a-1):
    for j in range(i+1,a):
        matches.append([teams[i], teams[j]])
    pos = 1
    for i in matches:
        print("Match{} : {} vs {}".format(pos, i[0], i[1]))
        pos = pos + 1
